# Context is the repo root; the image only needs agent/ + vestad/Dockerfile.

# Anything outside agent/ that's large or irrelevant to the image
apps/
node_modules/
target/
.git/
.github/
.claude/

# vestad/ — keep Dockerfile; drop bulky/unused things
vestad/target/
vestad/tests-integration/

# Python junk inside agent/
agent/.venv/
agent/.ruff_cache/
agent/.pytest_cache/
agent/tests/
agent/**/__pycache__/
agent/**/*.pyc
agent/**/*.egg-info/
# Dev-only tool configs the box never runs (ruff.toml DOES ship — see agent_embed.rs).
agent/pytest.ini
agent/ty.toml
agent/.hypothesis/
