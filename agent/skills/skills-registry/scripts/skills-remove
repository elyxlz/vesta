#!/usr/bin/env bash
# Uninstall a skill: drop it from data/installed-skills.txt and relink ~/.claude/skills.
# The skill's files stay on disk (full checkout); removing only deactivates it. A default
# skill reactivates on the next relink (link-skills.sh unions the shipped defaults back in).
set -euo pipefail
SKILL_NAME="${1:?Usage: skills-remove <skill-name>}"
cd ~
INSTALLED="agent/data/installed-skills.txt"

if grep -qxF "$SKILL_NAME" agent/core/default-skills.txt 2>/dev/null; then
    echo "'$SKILL_NAME' is a default skill: it reactivates on every relink and can't be deactivated."
    exit 0
fi
if ! grep -qxF "$SKILL_NAME" "$INSTALLED" 2>/dev/null; then
    echo "Skill '$SKILL_NAME' is not installed."
    exit 0
fi
{ grep -vxF "$SKILL_NAME" "$INSTALLED" || true; } > "$INSTALLED.tmp"
mv "$INSTALLED.tmp" "$INSTALLED"
bash ~/agent/core/skills/upstream-sync/scripts/link-skills.sh
echo "Removed '$SKILL_NAME'. Restart Vesta to deactivate it."
