#!/usr/bin/env bash
# Deactivate a skill: drop it from agent/data/active-skills.txt. The skill's files
# stay on disk (full checkout); deactivating only unlists it. A default skill reactivates
# on the next boot because the entrypoint unions the shipped defaults back in.
set -euo pipefail
SKILL_NAME="${1:?Usage: skills-deactivate <skill-name>}"
cd ~
ACTIVE="agent/data/active-skills.txt"
DEFAULTS="agent/core/default-skills.txt"

if grep -qxF "$SKILL_NAME" "$DEFAULTS" 2>/dev/null; then
    echo "'$SKILL_NAME' is a default skill: it reactivates on every boot and can't be deactivated."
    exit 0
fi
if ! grep -qxF "$SKILL_NAME" "$ACTIVE" 2>/dev/null; then
    echo "Skill '$SKILL_NAME' is not active."
    exit 0
fi
{ grep -vxF "$SKILL_NAME" "$ACTIVE" || true; } > "$ACTIVE.tmp"
mv "$ACTIVE.tmp" "$ACTIVE"
echo "Deactivated '$SKILL_NAME'. Restart Vesta to unload it."
