#!/usr/bin/env bash
# Install a skill: mark it in data/installed-skills.txt and relink ~/.claude/skills. Every
# optional skill already sits on disk (the workspace is a full checkout), so installing
# only activates it. Instant, offline, no git.
set -euo pipefail
SKILL_NAME="${1:?Usage: skills-install <skill-name>}"
cd ~
DEST="agent/skills/$SKILL_NAME"
INSTALLED="agent/data/installed-skills.txt"

if [ ! -f "$DEST/SKILL.md" ]; then
    echo "Error: no skill '$SKILL_NAME' (run skills-search to list available skills)." >&2
    exit 1
fi

mkdir -p agent/data
if grep -qxF "$SKILL_NAME" "$INSTALLED" 2>/dev/null; then
    echo "Skill '$SKILL_NAME' is already installed."
else
    printf '%s\n' "$SKILL_NAME" >> "$INSTALLED"
fi
bash ~/agent/core/skills/upstream-sync/scripts/link-skills.sh

echo "Installed '$SKILL_NAME'. Restart Vesta to activate it."
if [ -f "$DEST/SETUP.md" ]; then
    echo "This skill requires setup, read $DEST/SETUP.md for instructions."
fi
