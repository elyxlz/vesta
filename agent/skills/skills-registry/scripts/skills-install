#!/usr/bin/env bash
set -euo pipefail

SKILL_NAME="${1:?Usage: skills-install <skill-name>}"
SKILLS_DIR="$(cd "$(dirname "$0")/../.." && pwd)"
DEST="$SKILLS_DIR/$SKILL_NAME"

if [ -d "$DEST" ]; then
    echo "Skill '$SKILL_NAME' is already installed."
    exit 0
fi

# SETUP.md initialises sparse-checkout with `!/agent/skills/*/` so uninstalled
# skills stay off disk. `sparse-checkout add` appends a re-include pattern
# after that exclude (later patterns win), pulling this skill into the worktree
# while leaving the rest excluded. Future merges will track this skill normally.
echo "Installing '$SKILL_NAME' via sparse checkout..."

REPO_ROOT=$(git -C ~ rev-parse --show-toplevel)
git -C "$REPO_ROOT" sparse-checkout add "agent/skills/$SKILL_NAME"

# Fetch the skill content from upstream if not already available locally
if [ ! -d "$DEST" ]; then
    UPSTREAM_REF="${VESTA_UPSTREAM_REF:-}"
    if [ -n "$UPSTREAM_REF" ]; then
        git -C "$REPO_ROOT" fetch --depth 1 origin "$UPSTREAM_REF" 2>/dev/null || true
        git -C "$REPO_ROOT" checkout FETCH_HEAD -- "agent/skills/$SKILL_NAME" 2>/dev/null || true
    fi
fi

if [ ! -d "$DEST" ]; then
    # Remove from sparse checkout since the skill doesn't exist upstream
    git -C "$REPO_ROOT" sparse-checkout set $(git -C "$REPO_ROOT" sparse-checkout list | grep -v "^agent/skills/$SKILL_NAME$")
    echo "Error: skill '$SKILL_NAME' not found in registry."
    exit 1
fi

echo "Installed '$SKILL_NAME'. Restart Vesta to activate it."
if [ -f "$DEST/SETUP.md" ]; then
    echo "This skill requires setup — read $DEST/SETUP.md for instructions."
fi
