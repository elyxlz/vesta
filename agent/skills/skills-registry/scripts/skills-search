#!/usr/bin/env python3
"""Search the local skills registry (agent/skills/*), marking active ones. No network:
every skill is on disk (full checkout), so the local dir is the complete catalog."""

import json
import pathlib
import re
import sys

query = " ".join(sys.argv[1:]).lower()
skills_dir = pathlib.Path.home() / "agent" / "skills"
config_file = pathlib.Path.home() / "agent" / "data" / "config.json"
legacy_active_file = pathlib.Path.home() / "agent" / "data" / "active-skills.txt"
default_skills_file = pathlib.Path.home() / "agent" / "core" / "default-skills.txt"


def text_names(path):
    return path.read_text().split() if path.exists() else []


try:
    config = json.loads(config_file.read_text()) if config_file.exists() else {}
except json.JSONDecodeError:
    config = {}
configured = config["active_skills"] if isinstance(config, dict) and isinstance(config.get("active_skills"), list) else None
skill_name_re = re.compile(r"^[A-Za-z0-9][A-Za-z0-9._-]*$")
raw_active = [name for name in configured if isinstance(name, str)] if configured is not None else text_names(legacy_active_file)
active = {name.strip() for name in raw_active if skill_name_re.fullmatch(name.strip())}
active.update(text_names(default_skills_file))

results = []
for skill_md in sorted(skills_dir.glob("*/SKILL.md")):
    match = re.match(r"^---\n(.*?)\n---", skill_md.read_text(), re.DOTALL)
    fm = dict(re.findall(r"^(\w[\w-]*)\s*:\s*(.+)$", match.group(1), re.MULTILINE)) if match else {}
    dirname = skill_md.parent.name
    name = fm["name"] if "name" in fm else dirname
    desc = fm["description"] if "description" in fm else ""
    if not query or query in name.lower() or query in desc.lower():
        results.append((name, desc, dirname))

if not results:
    print(f"No skills found matching: {query}")
    sys.exit(0)

for name, desc, dirname in results:
    marker = " [active]" if dirname in active or name in active else ""
    print(f"{name}: {desc}{marker}")
