#!/usr/bin/env python3
"""Search the Vesta skills registry."""

import json
import pathlib
import sys
import urllib.request

INDEX_URL = "https://raw.githubusercontent.com/elyxlz/vesta/master/agent/skills-index.json"

query = " ".join(sys.argv[1:]).lower()

try:
    with urllib.request.urlopen(INDEX_URL, timeout=10) as resp:
        skills = json.load(resp)
except Exception as e:
    print(f"Failed to fetch skills index: {e}", file=sys.stderr)
    sys.exit(1)

skills_dir = pathlib.Path.home() / "vesta" / "skills"

results = [
    s for s in skills
    if not query
    or query in s["name"].lower()
    or query in s["description"].lower()
    or any(query in t for t in s.get("tags", []))
]

if not results:
    print(f"No skills found matching: {query}")
    sys.exit(0)

for s in results:
    installed = " [installed]" if (skills_dir / s["name"]).exists() else ""
    print(f"{s['name']}: {s['description']}{installed}")
