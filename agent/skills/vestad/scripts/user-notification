#!/usr/bin/env bash
set -euo pipefail

# Post a user-facing notification to vestad, which fans a `user_notification` delta to connected
# clients and an Expo push to backgrounded mobile. Agent-token authenticated and self-scoped by
# AGENT_NAME. Best-effort: a transport failure never surfaces (the caller's durable work already happened).
#
# Usage: user-notification <kind> <title> <body>    (kind in: message rate_limited)

KIND="${1:?Usage: user-notification <kind> <title> <body>}"
TITLE="${2:?Usage: user-notification <kind> <title> <body>}"
BODY="${3:?Usage: user-notification <kind> <title> <body>}"

REQUEST=$(python3 -c \
    'import json, sys; print(json.dumps({"kind": sys.argv[1], "title": sys.argv[2], "body": sys.argv[3]}))' \
    "$KIND" "$TITLE" "$BODY")

curl -sk -X POST "https://localhost:$VESTAD_PORT/agents/$AGENT_NAME/user-notification" \
    -H "X-Agent-Token: $AGENT_TOKEN" -H 'Content-Type: application/json' \
    -d "$REQUEST" >/dev/null || true
