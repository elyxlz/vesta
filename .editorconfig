root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{py,toml,yml,yaml,json,md,svelte,ts,js,html,css}]
indent_style = space
indent_size = 4

[*.{yml,yaml,json,svelte,ts,js,html,css}]
indent_size = 2

[*.rs]
indent_style = space
indent_size = 4

[Makefile]
indent_style = tab
