{
  "name": "@vesta/mobile",
  "private": true,
  "version": "0.1.180",
  "description": "Vesta native mobile app for iOS and Android",
  "license": "MIT",
  "main": "expo-router/entry",
  "scripts": {
    "start": "VESTA_APP_VARIANT=development VESTA_LOCAL_IOS_NO_PUSH=1 expo start --dev-client --scheme vesta-dev",
    "start:android": "VESTA_APP_VARIANT=development expo start --dev-client --scheme vesta-dev",
    "ios": "VESTA_APP_VARIANT=development VESTA_LOCAL_IOS_NO_PUSH=1 expo run:ios",
    "android": "VESTA_APP_VARIANT=development expo run:android",
    "prebuild": "expo prebuild",
    "lint": "expo lint",
    "check": "tsc --noEmit",
    "test": "vitest run",
    "postinstall": "patch-package"
  },
  "dependencies": {
    "@expo-google-fonts/archivo": "^0.4.2",
    "@expo-google-fonts/jetbrains-mono": "^0.4.1",
    "@expo-google-fonts/source-serif-4": "^0.4.1",
    "@expo/ui": "~57.0.7",
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@tanstack/react-query": "^5.101.3",
    "@vesta/core": "file:../core",
    "expo": "~57.0.8",
    "expo-audio": "~57.0.3",
    "expo-auth-session": "~57.0.5",
    "expo-camera": "~57.0.3",
    "expo-clipboard": "~57.0.1",
    "expo-constants": "~57.0.3",
    "expo-crypto": "~57.0.1",
    "expo-dev-client": "~57.0.8",
    "expo-device": "~57.0.1",
    "expo-font": "~57.0.0",
    "expo-glass-effect": "~57.0.1",
    "expo-haptics": "~57.0.1",
    "expo-linear-gradient": "~57.0.1",
    "expo-linking": "~57.0.4",
    "expo-notifications": "~57.0.7",
    "expo-router": "~57.0.8",
    "expo-secure-store": "~57.0.1",
    "expo-splash-screen": "~57.0.5",
    "expo-status-bar": "~57.0.1",
    "expo-symbols": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "expo-updates": "~57.0.9",
    "expo-web-browser": "~57.0.2",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-gesture-handler": "~2.32.0",
    "react-native-keyboard-controller": "1.21.9",
    "react-native-markdown-display": "7.0.2",
    "react-native-pager-view": "8.0.2",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "~4.26.0",
    "react-native-svg": "15.15.4",
    "react-native-webview": "13.16.1",
    "react-native-worklets": "0.10.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "eslint": "^9.39.5",
    "eslint-config-expo": "~57.0.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "patch-package": "^8.0.1",
    "typescript": "~6.0.3",
    "vitest": "^4.1.10"
  }
}
