{
  "productName": "Vesta",
  "version": "0.1.147",
  "identifier": "com.vestarun.app",
  "build": {
    "beforeDevCommand": "npm --workspace @vesta/web run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm --workspace @vesta/web run build",
    "frontendDist": "../../web/dist"
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Vesta",
        "decorations": true,
        "hiddenTitle": true,
        "titleBarStyle": "Overlay",
        "transparent": true,
        "height": 750,
        "width": 1200,
        "minWidth": 380,
        "minHeight": 380,
        "center": false,
        "resizable": true,
        "dragDropEnabled": false,
        "acceptFirstMouse": true,
        "zoomHotkeysEnabled": false,
        "visible": true,
        "windowEffects": {
          "effects": ["fullScreenUI", "mica"],
          "radius": 28,
          "state": "active"
        },
        "shadow": true,
        "backgroundThrottling": "disabled"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/elyxlz/vesta/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEFCOTlGN0E4QTAwM0ZFREEKUldUYS9nT2dxUGVacTJ3M1NuNGM3OVo0VEZoRFA1Y2pWZ2xpSjJiU1QrNXo2L3RNZkhyc0tVMDUK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": ["resources/*"],
    "macOS": {
      "entitlements": null
    }
  }
}
