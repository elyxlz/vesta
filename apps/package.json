{
  "name": "vesta-apps",
  "private": true,
  "workspaces": [
    "web",
    "desktop",
    "core"
  ],
  "scripts": {
    "core:lint": "npm -w @vesta/core run lint",
    "core:check": "npm -w @vesta/core run check",
    "core:test": "npm -w @vesta/core run test",
    "web:dev": "npm -w @vesta/web run dev",
    "web:build": "npm -w @vesta/web run build",
    "web:check": "npm -w @vesta/web run check",
    "web:lint": "npm -w @vesta/web run lint",
    "web:test": "npm -w @vesta/web run test",
    "desktop:dev": "npm -w @vesta/desktop run dev",
    "desktop:build": "npm -w @vesta/desktop run build",
    "mobile:start": "npm --prefix mobile run start",
    "mobile:ios": "npm --prefix mobile run ios",
    "mobile:android": "npm --prefix mobile run android",
    "mobile:check": "npm --prefix mobile run check"
  }
}
